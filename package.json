{
    "name": "omoi",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev:web",
        "dev:web": "npm run dev --workspace=apps/web",
        "dev:cool": "npm run dev:cool --workspace=apps/web",
        "dev:api": "npm run dev --workspace=apps/api",
        "dev:full": "turbo run dev --filter=web --filter=@omoi/api --concurrency=2",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "test:e2e": "turbo run test:e2e",
        "db:generate": "npm run db:generate --workspace=apps/api",
        "db:migrate": "npm run db:migrate --workspace=apps/api",
        "db:push": "npm run db:push --workspace=apps/api",
        "db:studio": "npm run db:studio --workspace=apps/api",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
    },
    "devDependencies": {
        "turbo": "^2.5.0",
        "prettier": "^3.5.0"
    },
    "packageManager": "npm@10.8.2",
    "engines": {
        "node": ">=20.0.0"
    }
}