generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  avatar        String?
  bio           String?
  phoneNumber   String?
  emailVerified DateTime?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  ratings      Rating[]
  reviews      Review[]
  userLists    UserList[]
  activities   Activity[]
  comparisonsA Comparison[] @relation("UserComparisonsA")
  comparisonsB Comparison[] @relation("UserComparisonsB")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Anime {
  id           String   @id @default(cuid())
  malId        Int      @unique
  title        String
  titleEnglish String?
  synopsis     String?
  imageUrl     String?
  episodes     Int?
  status       String?
  year         Int?
  season       String?
  studio       String?
  genres       String
  malScore     Float?
  avgGlobal    Float?   @default(0)
  avgAnimTier  Float?   @default(0)
  avgScenTier  Float?   @default(0)
  avgMusicTier Float?   @default(0)
  totalRatings Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings   Rating[]
  reviews   Review[]
  userLists UserList[]
}

model UserList {
  id        String     @id @default(cuid())
  userId    String
  animeId   String
  status    ListStatus @default(PLANNING)
  progress  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
}

model Rating {
  id          String   @id @default(cuid())
  userId      String
  animeId     String
  animTier    Tier
  scenTier    Tier
  musicTier   Tier
  globalScore Float
  globalTier  Tier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime  Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  review Review?

  @@unique([userId, animeId])
}

model Review {
  id        String   @id @default(cuid())
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  animeId   String
  ratingId  String   @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime  Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)
  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  animeId   String?
  content   String? // For extra info like "completed episode 12"
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comparison {
  id            String   @id @default(cuid())
  userAId       String
  userBId       String
  compatibility Float
  commonAnimes  String // JSON string of common IDs
  createdAt     DateTime @default(now())

  userA User @relation("UserComparisonsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("UserComparisonsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

enum Tier {
  S
  A
  B
  C
  D
}

enum ListStatus {
  WATCHING
  COMPLETED
  ON_HOLD
  DROPPED
  PLANNING
}

enum ActivityType {
  LIST_UPDATE
  RATING_POST
  REVIEW_POST
  STATUS_CHANGE
}
