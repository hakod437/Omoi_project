// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  avatar        String?
  bio           String?
  phoneNumber   String?   @unique
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?

  ratings       Rating[]
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]
  sentComparisons     Comparison[] @relation("SentBy")
  receivedComparisons Comparison[] @relation("ReceivedBy")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Anime {
  id            String    @id
  malId         Int       @unique
  title         String
  titleEnglish  String?
  synopsis      String?
  imageUrl      String?
  episodes      Int?
  status        String?
  year          Int?
  season        String?
  studio        String?
  genres        String[]
  malScore      Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  avgAnimTier   Float?
  avgScenTier   Float?
  avgMusicTier  Float?
  avgGlobal     Float?
  totalRatings  Int       @default(0)

  ratings       Rating[]
  reviews       Review[]
}

model Rating {
  id          String   @id @default(cuid())
  userId      String
  animeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  animTier    Tier
  scenTier    Tier
  musicTier   Tier

  globalScore Float
  globalTier  Tier

  user        User     @relation(fields: [userId], references: [id])
  anime       Anime    @relation(fields: [animeId], references: [id])
  review      Review?

  @@unique([userId, animeId])
}

enum Tier {
  S
  A
  B
  C
  D
}

model Review {
  id        String   @id @default(cuid())
  content   String   @db.Text
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  userId    String
  animeId   String
  ratingId  String   @unique

  user      User     @relation(fields: [userId], references: [id])
  anime     Anime    @relation(fields: [animeId], references: [id])
  rating    Rating   @relation(fields: [ratingId], references: [id])
}

model Comparison {
  id            String   @id @default(cuid())
  compatibility Float
  commonAnimes  String[]
  createdAt     DateTime @default(now())
  userAId       String
  userBId       String

  userA  User @relation("SentBy",     fields: [userAId], references: [id])
  userB  User @relation("ReceivedBy", fields: [userBId], references: [id])
  @@unique([userAId, userBId])
}
